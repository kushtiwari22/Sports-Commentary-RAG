# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Google Custom Search (for RAG web-scraping pipeline) ─────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_CX_ID=<your-custom-search-engine-id>

# ── ScraperAPI (optional — improves JS-rendered page scraping) ────────────────
SCRAPER_API_KEY=<your-scraperapi-key>

# ── Pathway vector store (defaults shown) ────────────────────────────────────
PATHWAY_HOST=0.0.0.0
PATHWAY_PORT=8765

# ── Gradio → FastAPI URL (defaults shown) ────────────────────────────────────
BACKEND_URL=http://127.0.0.1:8080
